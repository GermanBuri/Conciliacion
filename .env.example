APP_NAME=ConciliarBT API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-this-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=conciliarbt
POSTGRES_USER=conciliarbt
POSTGRES_PASSWORD=conciliarbt
DATABASE_URL=postgresql+psycopg://conciliarbt:conciliarbt@localhost:5432/conciliarbt
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000
FIRST_SUPERUSER_EMAIL=admin@conciliarbt.com
FIRST_SUPERUSER_PASSWORD=ChangeMe123!
FIRST_SUPERUSER_FULL_NAME=Administrador Inicial
UPLOAD_DIR=storage/uploads
MAX_UPLOAD_SIZE_MB=25
